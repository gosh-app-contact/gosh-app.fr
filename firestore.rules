rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Utilisateurs ─────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
      // Un coach peut mettre à jour coachStatus/accountType/friends/friendRequests d'un élève lors de l'acceptation
      allow update: if request.auth != null
                    && request.auth.uid != uid
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountType == 'coach'
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['coachStatus', 'accountType', 'friends', 'friendRequests']);
      // Un coach peut envoyer une demande d'accès nutrition (nutritionAccessPending)
      allow update: if request.auth != null
                    && request.auth.uid != uid
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountType == 'coach'
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['nutritionAccessPending']);
      // Un coach peut modifier l'objectif calorique si l'élève a donné son accord (nutritionCoachEnabled)
      allow update: if request.auth != null
                    && request.auth.uid != uid
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountType == 'coach'
                    && resource.data.nutritionCoachEnabled == true
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['calorieGoal', 'calorieGoalManual', 'calorieGoalUpdatedAt', 'coachMacroManual', 'coachMacroProteins', 'coachMacroFats', 'coachMacroCarbs', 'coachStartedAt']);
      // N'importe quel utilisateur peut se retirer des listes sociales d'un autre (suppression de compte)
      allow update: if request.auth != null
                    && request.auth.uid != uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['friends', 'following', 'followers', 'friendRequests', 'blockedUsers', 'blockedBy']);

      // État de l'app (profil, historique poids, etc.) : strictement privé
      match /appState/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Journal alimentaire : strictement privé
      match /repas/{profileId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Logs de séances : strictement privés
      match /workoutLogs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Planning d'entraînement : écriture aussi par le coach (qui envoie le plan)
      match /training/{profileId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }

      // Commentaires postés (index dénormalisé)
      match /sentComments/{commentId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Posts & commentaires ──────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if request.auth != null;
      // Création : authentifié, l'uid doit correspondre
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      // Modification (likes, commentCount) : authentifié
      allow update: if request.auth != null;
      // Suppression : auteur ou admin
      allow delete: if request.auth != null
                    && (resource.data.uid == request.auth.uid
                        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountType == 'admin');

      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
                      && request.resource.data.uid == request.auth.uid;
        allow update: if request.auth != null
                      && resource.data.uid == request.auth.uid;
        allow delete: if request.auth != null
                      && (resource.data.uid == request.auth.uid
                          || get(/databases/$(database)/documents/posts/$(postId)).data.uid == request.auth.uid
                          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountType == 'admin');
      }
    }

    // ── Notifications (in-app feed) ───────────────────────────────────────────
    match /notifications/{uid} {
      allow read, delete: if request.auth != null && request.auth.uid == uid;
      match /items/{notifId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if request.auth != null;
      }
    }

    // ── Chats coach-élève ─────────────────────────────────────────────────────
    match /chats/{chatId} {
      // Seuls les participants peuvent lire/écrire
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participants;
      // Participants peuvent supprimer le chat (suppression de compte)
      allow delete: if request.auth != null
                    && request.auth.uid in resource.data.participants;

      match /messages/{msgId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
                      && request.resource.data.uid == request.auth.uid;
        allow update: if false;
        // Participants peuvent supprimer les messages (suppression de compte)
        allow delete: if request.auth != null
                      && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // ── Clubs ─────────────────────────────────────────────────────────────────
    match /clubs/{clubId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.memberIds;
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.ownerId;

      match /messages/{msgId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
                      && request.resource.data.uid == request.auth.uid;
        allow update: if false;
        // Auteur du message ou owner du club peuvent supprimer (suppression de compte, dissolution)
        allow delete: if request.auth != null
                      && (resource.data.uid == request.auth.uid
                          || request.auth.uid == get(/databases/$(database)/documents/clubs/$(clubId)).data.ownerId);
      }

      match /notifications/{notifId} {
        allow read: if request.auth != null
                    && resource.data.toUid == request.auth.uid;
        allow write: if request.auth != null;
      }
    }

    // ── GoshOffs ──────────────────────────────────────────────────────────────
    match /goshoffs/{goshOffId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Coach : codes d'accès ─────────────────────────────────────────────────
    match /coachCodes/{code} {
      allow read: if request.auth != null;
      // Écriture réservée aux coachs ou à la suppression par l'admin
      allow write: if request.auth != null;
    }

    // ── Coach : demandes élève → coach ────────────────────────────────────────
    match /coachRequests/{requestId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Coach : liste d'élèves ────────────────────────────────────────────────
    match /coachStudents/{coachUid} {
      allow delete: if request.auth != null && request.auth.uid == coachUid;
      match /students/{studentUid} {
        allow read: if request.auth != null
                    && (request.auth.uid == coachUid || request.auth.uid == studentUid);
        allow write: if request.auth != null;
      }
    }

    // ── Coach : séances créées par le coach ───────────────────────────────────
    match /coachSessions/{coachUid} {
      allow delete: if request.auth != null && request.auth.uid == coachUid;
      match /items/{sessionId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == coachUid;
      }
    }

    // ── Planning envoyé à l'élève par le coach ────────────────────────────────
    match /studentTraining/{studentUid} {
      allow read: if request.auth != null
                  && (request.auth.uid == studentUid
                      || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountType == 'coach');
      allow write: if request.auth != null;
    }

    // ── Bibliothèque de séances du coach ─────────────────────────────────────
    match /coachLibrary/{coachUid} {
      match /sessions/{sessionId} {
        allow read: if request.auth != null && request.auth.uid == coachUid;
        allow write: if request.auth != null && request.auth.uid == coachUid;
      }
    }

    // ── Signalements ──────────────────────────────────────────────────────────
    match /reports/{reportId} {
      // Admin : tout lire. Reporter ou signalé : leurs propres rapports (droit à l'effacement RGPD)
      allow read: if request.auth != null
                  && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountType == 'admin'
                      || resource.data.reporterUid == request.auth.uid
                      || resource.data.reportedUid == request.auth.uid);
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountType == 'admin';
      // Reporter ou signalé peuvent supprimer (suppression de compte), admin aussi
      allow delete: if request.auth != null
                    && (resource.data.reporterUid == request.auth.uid
                        || resource.data.reportedUid == request.auth.uid
                        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountType == 'admin');
    }

    // ── Tout le reste est interdit ────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
